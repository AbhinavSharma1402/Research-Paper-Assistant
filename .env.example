# JWT secret key used to sign access tokens
e.g. JWT_SECRET_KEY=your-very-secure-secret
JWT_SECRET_KEY=your_jwt_secret_key

# OpenAI API key for the chat model
e.g. OPENAI_API_KEY=sk-...
OPENAI_API_KEY=your_openai_api_key

# Database configuration
database_url for Postgres or SQLite
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/research_assistant

# Local storage paths
VECTOR_STORE_ROOT=./vectorstore
UPLOAD_DIR=./uploads

# Streamlit frontend uses this backend API base URL
API_BASE_URL=http://localhost:8000/api
